{
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^https?://"
      }
    },
    "status": {
      "type": "string",
      "const": "success"
    }
  },
  "additionalProperties": false
}